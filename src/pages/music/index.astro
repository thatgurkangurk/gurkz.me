---
import { getSession } from "auth-astro/server";
import { db } from "../../db";
import Layout from "../../layouts/Layout.astro";
import { CreateForm, createIdForm } from "../../components/music/_Create";
import { musicIds as musicIdsTable } from "../../db/schema";
import { IdFormatEnum } from "./_types";
import { FormatSelector } from "../../components/music/_FormatSelector";
import { idFormatStore } from "./_idFormat";
import MusicId from "~/components/music/music-id.astro";
import { actions } from "astro:actions";

const res = await Astro.locals.form.getData(createIdForm);
const session = await getSession(Astro.request);
const idFormat = IdFormatEnum.safeParse(
    await Astro.cookies.get("id_format")?.value
);

if (idFormat.error) {
    await Astro.cookies.set("id_format", "DEFAULT"); // fall back to default
}

if (res?.data) {
    if (!session || !session.user) {
        return new Response(
            JSON.stringify({
                message: "you need to be signed in to do that",
            }),
            {
                status: 401,
            }
        );
    }

    if (!session.user.permissions.includes("CREATE_MUSIC_IDS")) {
        return new Response(
            JSON.stringify({
                message: "you do not have permission to do that",
            }),
            {
                status: 403,
            }
        );
    }

    await db.insert(musicIdsTable).values({
        robloxId: parseInt(res.data.id),
        name: res.data.name,
        createdById: session.user.id,
    });
}

const musicIds = await db.query.musicIds.findMany({
    orderBy: (table, { desc }) => [desc(table.created)],
    with: {
        creator: {
            columns: {
                name: true,
                id: true,
                image: true,
            },
        },
    },
});

idFormatStore.set(idFormat.data ? idFormat.data : "DEFAULT");

const result = Astro.getActionResult(actions.music.deleteMusicId);
---

<Layout title="music">
    <h1 class="text-4xl">music id list</h1>
    {
        session?.user &&
            session.user.permissions.includes("CREATE_MUSIC_IDS") && (
                <>
                    <CreateForm client:load />
                    <br />
                </>
            )
    }

    <FormatSelector client:load />

    {
        result?.error && (
            <>
                <div>
                    <p>something went wrong!</p>
                    <p>code: {result.error.code}</p>
                    <p>message: {result.error.message}</p>
                </div>
            </>
        )
    }

    {musicIds.map((musicId) => <MusicId id={musicId} />)}
</Layout>
