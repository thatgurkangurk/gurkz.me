<div class="container_lyrics" data-start="0">
	<Lyric start="0" duration="2000" appendBr={false} text="Forms FORM-29827281-12:" />
	<Lyric start="2000" duration="2000" appendBr={true} text="Test Assessment Report" />
	<br data-show-offset="4010" /><br data-show-offset="4020" />
	<Lyric start="6870" duration="2050" appendBr={true} text="This was a triumph." />
	<Lyric start="10820" duration="2100" appendBr={true} text="I'm making a note here:" />
	<Lyric start="12930" duration="1800" appendBr={true} text="HUGE SUCCESS." />
	<Lyric start="15730" duration="2360" appendBr={true} text="It's hard to overstate" />
	<Lyric start="18130" duration="2710" appendBr={true} text="my satisfaction." />
	<Lyric start="22970" duration="1760" appendBr={true} text="Aperture Science" ascii={AsciiEnum.APERTURE} />

	<Lyric start="26830" duration="1570" appendBr={true} text="We do what we must" />
	<Lyric start="28600" duration="1460" appendBr={false} text="because we can." />
	<Lyric start="31930" duration="1550" appendBr={false} text="For the good" />
	<Lyric start="33480" duration="1530" appendBr={true} text="of all of us." />
	<Lyric
		start="35289"
		duration="1741"
		appendBr={true}
		text="Except the ones who are dead."
		ascii={AsciiEnum.BIOHAZARD}
	/>
	<Lyric start="37030" duration="400" appendBr={true} text="" />
	<Lyric
		start="37430"
		duration="1858"
		appendBr={true}
		text="But there's no sense crying"
		ascii={AsciiEnum.APERTURE}
	/>
	<Lyric start="39298" duration="1782" appendBr={true} text="over every mistake." />
	<Lyric start="41280" duration="1985" appendBr={true} text="You just keep on trying" />
	<Lyric start="43275" duration="1366" appendBr={false} text="till you run out of" />
	<Lyric start="44641" duration="400" appendBr={true} text="cake." />
	<Lyric start="45227" duration="1970" appendBr={true} text="And the Science gets done." ascii={AsciiEnum.ATOM} />
	<Lyric start="47197" duration="1970" appendBr={true} text="And you make a neat gun." />
	<Lyric start="49187" duration="1520" appendBr={true} text="For the people who are" ascii={AsciiEnum.APERTURE} />
	<Lyric start="50727" duration="1500" appendBr={true} text="still alive." />
</div>

<div class="container_lyrics" data-start="53827">
	<Lyric start="0" duration="550" appendBr={true} text="Forms FORM-55551-5:" />
	<Lyric start="550" duration="1100" appendBr={true} text="Personnel File Addendum:" />
	<br data-show-offset="1650" />
	<Lyric start="2310" duration="2350" appendBr={true} text="Dear <<Subject Name Here>>," />
	<br data-show-offset="4660" />
	<Lyric start="4720" duration="1917" appendBr={true} text="I'm not even angry." />
	<Lyric start="9005" duration="697" appendBr={false} text="I'm being" />
	<Lyric start="9702" duration="650" appendBr={false} text="so" />
	<Lyric start="10352" duration="906" appendBr={false} text="sincere" />
	<Lyric start="11258" duration="1115" appendBr={true} text="right now." />
	<Lyric start="13998" duration="650" appendBr={false} text="Even" />
	<Lyric start="14648" duration="1347" appendBr={false} text="though you" />
	<Lyric start="15995" duration="488" appendBr={false} text="broke" ascii={AsciiEnum.BROKEN_HEART} />
	<Lyric start="16483" duration="998" appendBr={true} text="my heart." />
	<Lyric start="17481" duration="325" appendBr={false} text="And" />
	<Lyric start="17806" duration="488" appendBr={false} text="killed" />
	<Lyric start="18294" duration="557" appendBr={true} text="me." />
	<Lyric start="20851" duration="1649" appendBr={true} text="And tore me to pieces." ascii={AsciiEnum.EXPLOSION} />
	<Lyric start="24822" duration="1440" appendBr={false} text="And threw every piece" />
	<Lyric start="26264" duration="580" appendBr={false} text="into" />
	<Lyric start="27239" duration="882" appendBr={true} text="a fire." ascii={AsciiEnum.FIRE} />
	<Lyric start="29770" duration="1400" appendBr={false} text="As they burned" />
	<Lyric start="31170" duration="1509" appendBr={true} text="it hurt because" />
	<Lyric start="33004" duration="1625" appendBr={true} text="I was so happy for you!" ascii={AsciiEnum.CHECK} />
	<Lyric start="35070" duration="2067" appendBr={true} text="Now these points of data" />
	<Lyric start="37137" duration="1950" appendBr={true} text="make a beautiful line." />
	<Lyric start="39087" duration="2020" appendBr={true} text="And we're out of beta." />
	<Lyric start="41107" duration="1950" appendBr={true} text="We're releasing on time." />
	<Lyric
		start="43057"
		duration="2113"
		appendBr={true}
		text="So I'm GLaD. I got burned."
		ascii={AsciiEnum.EXPLOSION}
	/>
	<Lyric
		start="45170"
		duration="2020"
		appendBr={true}
		text="Think of all the things we learned"
		ascii={AsciiEnum.ATOM}
	/>
	<Lyric start="47190" duration="1556" appendBr={true} text="for the people who are" ascii={AsciiEnum.APERTURE} />
	<Lyric start="48746" duration="395" appendBr={false} text="still" />
	<Lyric start="49141" duration="1440" appendBr={true} text="alive." />
</div>

