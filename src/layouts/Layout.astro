---
import Meta from "~/components/Meta.astro";
---

<html
	lang="en"
	class="ml-[calc(100vw-100%)] mr-0 h-[96dvh] touch-manipulation scroll-smooth antialiased [color-scheme:dark]"
>
	<Meta />
	<body
		class=`font-geist max-w-64ch gap-10px m-auto grid h-full grid-cols-[1fr] grid-rows-[1fr] p-4 text-left [grid-template-areas:_"main"_"footer"]`
	>
		<main class="[grid-area:main]">
			<slot />
		</main>
	</body>
</html>
