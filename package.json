{
    "name": "gurkz.me",
    "type": "module",
    "packageManager": "pnpm@10.0.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "@swc/core",
            "esbuild"
        ]
    },
    "scripts": {
        "dev": "vinxi dev",
        "build": "vinxi build",
        "start": "vinxi start",
        "version": "vinxi version",
        "prettier:format": "prettier --write \"**/*.{ts,tsx,js,md,mdx,css,yaml}\"",
        "prettier:check": "prettier --check \"**/*.{ts,tsx,js,md,mdx,css,yaml}\"",
        "eslint:check": "eslint \"**/*.{ts,tsx,js,md,mdx,css,yaml}\"",
        "eslint:fix": "eslint --fix \"**/*.{ts,tsx,js,md,mdx,css,yaml}\""
    },
    "dependencies": {
        "@fontsource-variable/space-grotesk": "^5.1.1",
        "@kobalte/core": "^0.13.7",
        "@solidjs/meta": "^0.29.4",
        "@solidjs/router": "^0.15.3",
        "@solidjs/start": "^1.0.11",
        "@tailwindcss/vite": "^4.0.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-solid": "^0.473.0",
        "solid-js": "^1.9.4",
        "tailwind-merge": "^2.6.0",
        "tailwindcss": "^4.0.0",
        "tailwindcss-animate": "^1.0.7",
        "vinxi": "^0.4.3"
    },
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@eslint/js": "^9.18.0",
        "@trivago/prettier-plugin-sort-imports": "^5.2.1",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin": "^1.0.1",
        "eslint-plugin-solid": "^0.14.5",
        "globals": "^15.14.0",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "^0.6.10",
        "typescript-eslint": "^8.21.0",
        "vite-plugin-lucide-preprocess": "^1.2.4"
    },
    "prettier": {
        "trailingComma": "es5",
        "tabWidth": 4,
        "semi": true,
        "singleQuote": false,
        "jsxSingleQuote": false,
        "plugins": [
            "prettier-plugin-tailwindcss",
            "@trivago/prettier-plugin-sort-imports"
        ],
        "tailwindFunctions": [
            "clsx",
            "cn"
        ]
    }
}
