// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URI")
}

model Pokemon {
  id           Int    @id @unique
  votesFor     Vote[] @relation("for")
  votesAgainst Vote[] @relation("against")
}

model Vote {
  id    String  @id @default(cuid())
  for   Pokemon @relation("for", fields: [forId], references: [id])
  forId Int

  against   Pokemon @relation("against", fields: [againstId], references: [id])
  againstId Int
}
